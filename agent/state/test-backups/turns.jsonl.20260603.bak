tem-reminder>","payload":{"issue":{"id":"72dbd7a6-d8ba-4710-b4a1-dcd79a8d806e","workspace_id":"40d675ba-4dec-47dd-9222-79c0345c493f","appfolio_srn":"TEST-FRESH-2","name":"Leaking kitchen faucet","description":"Tenant reports the kitchen faucet drips constantly and pools under the sink.","urgent":true,"created_at":"2026-05-25T08:34:51.321866+00:00","property_id":"196dc99d-4fc7-4e83-9b14-25a14dfd4f1f","vendor_id":"455e483b-d931-4d59-80fa-8f877d5a706e","tenant":{"id":"882e1225-8726-4a5b-a111-b96721bb6fa2","name":"Andrew"},"property":{"id":"196dc99d-4fc7-4e83-9b14-25a14dfd4f1f","name":"Hub Champaign"},"unit":{"id":"1bdc9eda-6988-4ca3-9e85-39419874582e","name":"Unit 701 Hub Champaign"},"vendor":{"name":"Mario"},"urgency_reason":"A constant drip that is pooling under the sink can cause water damage or mold if it waits until the next business day."},"candidate_vendors":[{"id":"b40d494d-e62c-42f6-a814-474e78c5c463","name":"24/7 ELECTRIC INC"},{"id":"adfa809f-8e69-4961-9e83-2ecef84db8dd","name":"911 Restoration"},{"id":"46743da3-c16b-4b9b-885e-c05e2e39830e","name":"A Precision Roofing, INC."},{"id":"5d144830-f7d8-48ea-9858-ce472831c2b1","name":"Abraham"},{"id":"f42c5500-adde-4c09-ad57-e9fdca37180a","name":"Ace Locksmith"},{"id":"d137ad03-4407-40f5-b11a-3222aa6a175b","name":"Airtek Pros Air Conditioning & Heating Inc"},{"id":"2cadab52-daed-410d-899e-e9d9ffe916c2","name":"Alex's General Construction"},{"id":"8162f323-b066-41bb-8ba6-1c5979dd1a62","name":"Angel Plumbing Services"},{"id":"4cac9d41-d67f-4001-85e4-ddcab4c06f64","name":"California Heat Air Conditioning"},{"id":"c68c19a8-b18c-4f7c-a71e-86973de2e56c","name":"Cross Appliance Inc"},{"id":"00879b3d-7a77-480d-acc8-cab74c1b3ab0","name":"Dever Pest Control"},{"id":"fedc5554-60ab-425e-9a98-67e781708f27","name":"Fajardo, Ricardo"},{"id":"7d749d0e-f735-4857-a46b-5d23b3844116","name":"Guox Maintenance & Remodel"},{"id":"7dbeb2df-57d0-4d14-b562-e9d95a05e73b","name":"Gutters By Ruby"},{"id":"5178fea2-5b7e-420c-bc12-85a29da59962",