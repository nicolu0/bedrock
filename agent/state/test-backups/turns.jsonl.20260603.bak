ia vector recall on question (conf 0.55)"},{"kind":"belief","data":{"id":"44b960ad-0dd1-454f-b6f0-a0ecd62eb9bc","claim":"Jose Rivera Landscaping is the go-to landscaping vendor at 742 N Cherokee (5 jobs).","scope":{"jobs":5,"kind":"property_goto","trade":"landscaping"},"tags":["go-to","property-scoped"]},"via":"semantic","confidence":0.55,"score":0.55,"provenance":"belief \"Jose Rivera Landscaping is the go-to landscaping vendor at 742 N Cherokee (5 jobs).\" — matched via vector recall on question (conf 0.55)"},{"kind":"belief","data":{"id":"0979138c-b4f9-4775-91a0-cfb0cc6623a0","claim":"Jimmy’s Pool Service is the go-to pool vendor at 742 N Cherokee (5 jobs).","scope":{"jobs":5,"kind":"property_goto","trade":"pool"},"tags":["go-to","property-scoped"]},"via":"semantic","confidence":0.55,"score":0.55,"provenance":"belief \"Jimmy’s Pool Service is the go-to pool vendor at 742 N Cherokee (5 jobs).\" — matched via vector recall on question (conf 0.55)"},{"kind":"belief","data":{"id":"0d8adfb1-41d5-444f-9565-62b5db4ebfe8","claim":"Rightway Apartment Service is the go-to handyman vendor at 2135 Ivar Ave (4 jobs).","scope":{"jobs":4,"kind":"property_goto","trade":"handyman"},"tags":["go-to","property-scoped"]},"via":"semantic","confidence":0.5,"score":0.5,"provenance":"belief \"Rightway Apartment Service is the go-to handyman vendor at 2135 Ivar Ave (4 jobs).\" — matched via vector recall on question (conf 0.50)"},{"kind":"observation","data":{"id":"a15b4a5d-71ba-4c88-a617-09a5f9749760","summary":"Raptor Appliance Repair handled garbage disposal not activating from light switch at 9th St Bungalow Home LLC unit 12.","ts":"2026-06-02T05:42:46.752719+00:00","tags":["appliance","disposal","electrical","status-resolved"]},"via":"structural","confidence":0.5,"score":0.49211533967008597,"provenance":"obs \"Raptor Appliance Repair handled garbage disposal not activating from light switch at 9th St Bungalow Home LLC unit 12.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"eb3db6d7-8103-404f-ac10-37ed58b4ad57","summary":"Bondy Service handled communal washer/dryer not powering on, app error, at 9th St Bungalow Home LLC unit 9.","ts":"2026-06-02T05:42:42.154582+00:00","tags":["laundry","washer","dryer","vendor-dispatch"]},"via":"structural","confidence":0.5,"score":0.4921147345715999,"provenance":"obs \"Bondy Service handled communal washer/dryer not powering on, app error, at 9th St Bungalow Home LLC unit 9.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"071c393c-d5a6-4d2b-8c9f-90c484ec9485","summary":"ASAP Locksmith rekeyed front + back door knobs at 9th St Bungalow Home LLC unit 8.","ts":"2026-06-02T05:42:38.316295+00:00","tags":["locks","rekey","lock","status-resolved"]},"via":"structural","confidence":0.5,"score":0.4921142294899622,"provenance":"obs \"ASAP Locksmith rekeyed front + back door knobs at 9th St Bungalow Home LLC unit 8.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"f4a07b73-9271-44a4-b7ca-9dfaccd0d56a","summary":"Raptor Appliance Repair handled freezer leaking into fridge, clogged defrost drain, at 9th St Bungalow Home LLC unit 13.","ts":"2026-06-02T05:42:36.999501+00:00","tags":["appliance","fridge","leak","status-resolved"]},"via":"structural","confidence":0.5,"score":0.4921140561725942,"provenance":"obs \"Raptor Appliance Repair handled freezer leaking into fridge, clogged defrost drain, at 9th St Bungalow Home LLC unit 13.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"bfd22b22-a603-4d7d-bcbe-65a143360f25","summary":"A1 Service Appliances fixed AC that would not power on at 9th St Bungalow Home LLC unit 9.","ts":"2026-06-02T05:42:34.068593+00:00","tags":["hvac","ac","appliance","status-resolved"]},"via":"structural","confidence":0.5,"score":0.49211367045283944,"provenance":"obs \"A1 Service Appliances fixed AC that would not power on at 9th St Bungalow Home LLC unit 9.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"f03f2b3b-4cfa-413c-a3e0-c3e92a78f395","summary":"A1 Service Appliances handled AC making loud fan noise + not turning off at 9th St Bungalow Home LLC unit 1.","ts":"2026-06-02T05:42:33.625259+00:00","tags":["hvac","ac","appliance","status-resolved"]},"via":"structural","confidence":0.5,"score":0.49211361215404237,"provenance":"obs \"A1 Service Appliances handled AC making loud fan noise + not turning off at 9th St Bungalow Home LLC unit 1.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"79c343eb-d8b9-40d6-bd20-540c8adf039f","summary":"A1 Service Appliances handled fridge/freezer not cooling after defrost at 9th St Bungalow Home LLC unit 12.","ts":"2026-06-02T05:42:32.302069+00:00","tags":["appliance","fridge","status-resolved"]},"via":"structural","confidence":0.5,"score":0.49211343804729213,"provenance":"obs \"A1 Service Appliances handled fridge/freezer not cooling after defrost at 9th St Bungalow Home LLC unit 12.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"96287cda-6ee7-468b-bc8e-83d1fac3c6de","summary":"Reckon & Reckon Plumbing snaked plumbing line at 9th St Bungalow Home LLC unit 12.","ts":"2026-06-02T05:42:31.047668+00:00","tags":["plumbing","drain","snake","status-resolved"]},"via":"structural","confidence":0.5,"score":0.4921132728893963,"provenance":"obs \"Reckon & Reckon Plumbing snaked plumbing line at 9th St Bungalow Home LLC unit 12.\" — property:9th St Bungalow Home LLC, 2026-06-02"},{"kind":"observation","data":{"id":"907de00c-7a69-4a78-a724-2c70ba44f03c","summary":"Rightway Apartment Service handled washer flooding onto floor at 9th St Bungalow Home LLC unit 12.","ts":"2026-06-02T05:42:30.199651+00:00","tags":["handyperson","washer","leak","laundry","status-resolved"]},"via":"structural","confidence":0.5,"score":0.49211316129269805,"provenance":"obs \"Rightway Apartment Ser